rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Fellows Collection
    match /fellows/{fellowId} {
      allow read: if true; // Publicly accessible to display candidates
      
      // Allow updates if user is authenticated and is the fellow themselves
      allow update: if isAuthenticated() && 
        (request.auth.uid == fellowId || request.auth.token.email == resource.data.email) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'skills', 'goal', 'github', 'linkedin', 'portfolio', 'videoUrl', 'bio', 'initials']);
      
      allow create, delete: if isAuthenticated() && request.auth.uid == "mock-admin-uid-123"; // Admin only
    }

    // Device Tokens Collection
    match /device_tokens/{userId} {
      allow read, write: if isOwner(userId);
      
      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Nominations Collection
    match /nominations/{nominationId} {
      allow read: if isAuthenticated();
      allow create: if true; // Public nomination submissions permitted
      allow update, delete: if isAuthenticated(); // Admin approvals
    }

    // Global Metrics
    match /metrics/{metricId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Stripe webhooks idempotency events collection
    match /stripe_events/{eventId} {
      allow read, write: if false; // Admin SDK only
    }

    // Firebase Trigger Email mail collection
    match /mail/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // Public Feed Collection for Donor Feed
    match /public_feed/{feedId} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }
  }
}
